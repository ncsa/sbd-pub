#!/usr/bin/env bash
#SBATCH --job-name=sbd_run
#SBATCH --output=slurm_%x_%j.out
#SBATCH --error=slurm_%x_%j.err
#SBATCH --time=02:00:00
#SBATCH --nodes=1
#SBATCH --gpus-per-task=1
#SBATCH --exclude=x1000c7s2b1n0,x1000c1s5b1n0
#SBATCH --exclusive

# sbatch_run.sh - Unified SLURM submission script for SBD
# IMPORTANT: Build on login node first with: source env_setup.sh && make build
#
# Usage:
#   sbatch --ntasks-per-node=8 --cpus-per-task=8 --export=MODE=benchmark,DATASET=fe4s4,REPLICATES=3 sbatch_run.sh
#   sbatch --ntasks-per-node=8 --cpus-per-task=8 --export=MODE=profile,DATASET=n2 sbatch_run.sh
#
# For Frontier (8 GPUs/node, 8 cores/rank, no SMT):
#   sbatch --ntasks-per-node=8 --cpus-per-task=8 ...
# If system reserves cores, reduce to 7:
#   sbatch --ntasks-per-node=8 --cpus-per-task=7 ...
#
# To override MPI decomposition:
#   sbatch --ntasks-per-node=8 --cpus-per-task=8 --export=MODE=benchmark,ADET_COMM=4,BDET_COMM=4,TASK_COMM=1 sbatch_run.sh

# === Define Paths ===
BASE_DIR=$(cd "$SLURM_SUBMIT_DIR/.." && pwd)
SRC_DIR="$BASE_DIR/src"
DATA_DIR="$BASE_DIR/data"
BENCHMARK_DIR="$BASE_DIR/benchmarks"
EXE_PATH="$SRC_DIR/diag"
ANALYZER_PY="$BENCHMARK_DIR/summarize.py"
ANALYSIS_SCRIPT="$BENCHMARK_DIR/show-profile-tree.py"
ENV_SETUP="$BASE_DIR/env_setup.sh"

# === Configuration ===
MODE=${MODE:-benchmark} # benchmark or profile
DATASET=${DATASET:-n2}
REPLICATES=${REPLICATES:-5} # Only used in benchmark mode
ITERATIONS=${ITERATIONS:-2} # 2 for benchmark, 1 for profile

# === MPI Decomposition ===
TOTAL_TASKS=$((SLURM_NNODES * SLURM_NTASKS_PER_NODE))

# Function to find optimal square-ish 2D decomposition
# Tries to find factors close to sqrt(n) for balanced communication
find_square_decomposition() {
  local n=$1
  local best_ratio=999999
  local best_a=1
  local best_b=$n

  # Calculate sqrt once
  local sqrt_n=$(awk "BEGIN {printf \"%.0f\", sqrt($n)}")

  # Search from sqrt down to 1 for most square-like factorization
  for ((i = sqrt_n; i >= 1; i--)); do
    if [ $((n % i)) -eq 0 ]; then
      local j=$((n / i))
      # Calculate aspect ratio (always >= 1)
      local ratio=$(awk "BEGIN {printf \"%.2f\", $j / $i}")

      # Keep track of most square-like (smallest ratio)
      local is_better=$(awk "BEGIN {print ($ratio < $best_ratio) ? 1 : 0}")
      if [ "$is_better" -eq 1 ]; then
        best_ratio=$ratio
        best_a=$i
        best_b=$j
      fi

      # Perfect square found - stop searching
      if [ $i -eq $j ]; then
        break
      fi
    fi
  done

  ADET_COMM=$best_a
  BDET_COMM=$best_b
  TASK_COMM=1

  return 0
}

# Allow user to override decomposition via environment variables
if [ -n "$ADET_COMM" ] && [ -n "$BDET_COMM" ]; then
  TASK_COMM=${TASK_COMM:-1}
  echo "Using user-specified MPI decomposition: ADET=$ADET_COMM, BDET=$BDET_COMM, TASK=$TASK_COMM"
else
  # Auto-detect optimal decomposition
  if find_square_decomposition $TOTAL_TASKS; then
    echo "Auto-detected MPI decomposition: ADET=$ADET_COMM, BDET=$BDET_COMM, TASK=$TASK_COMM"
  else
    echo "ERROR: Failed to decompose $TOTAL_TASKS tasks"
    exit 1
  fi
fi

# Validate the decomposition matches total tasks
PRODUCT=$((ADET_COMM * BDET_COMM * TASK_COMM))
if [ $PRODUCT -ne $TOTAL_TASKS ]; then
  echo "========================================="
  echo "ERROR: MPI decomposition invalid!"
  echo "========================================="
  echo "  TOTAL_TASKS = $TOTAL_TASKS"
  echo "  ADET_COMM × BDET_COMM × TASK_COMM = $ADET_COMM × $BDET_COMM × $TASK_COMM = $PRODUCT"
  echo ""
  echo "The product must equal the total number of tasks."
  echo ""
  echo "To manually specify decomposition, use:"
  echo "  sbatch --export=ADET_COMM=X,BDET_COMM=Y,TASK_COMM=Z,... sbatch_run.sh"
  echo "========================================="
  exit 1
fi

# === Job Info ===
echo "========================================="
echo "SBD ${MODE^^} Job - MI250X System"
echo "========================================="
echo "Job ID:          $SLURM_JOB_ID"
echo "Mode:            $MODE"
echo "Nodes:           $SLURM_NNODES ($SLURM_NODELIST)"
echo "Tasks/Node:      $SLURM_NTASKS_PER_NODE"
echo "CPUs/Task:       $SLURM_CPUS_PER_TASK"
echo "Total Tasks:     $TOTAL_TASKS"
echo "MPI Decomp:      ADET=$ADET_COMM × BDET=$BDET_COMM × TASK=$TASK_COMM = $PRODUCT"
echo "Dataset:         $DATASET"
if [ "$MODE" = "benchmark" ]; then
  echo "Replicates:      $REPLICATES"
fi
echo "========================================="

# === Load Environment ===
if [ -f "$ENV_SETUP" ]; then
  echo "Loading environment from: $ENV_SETUP"
  source "$ENV_SETUP"
else
  echo "ERROR: Environment setup file not found: $ENV_SETUP"
  exit 1
fi

# === Check Executable ===
if [ ! -f "$EXE_PATH" ]; then
  echo "ERROR: Executable not found at $EXE_PATH"
  echo "Please build first: source env_setup.sh && make build"
  exit 1
fi
echo "Using executable: $EXE_PATH"

# === Override OpenMP settings for SLURM ===
# Override OMP_NUM_THREADS based on SLURM allocation
export OMP_NUM_THREADS=$SLURM_CPUS_PER_TASK

# Ensure LD_LIBRARY_PATH is exported to srun tasks
export LD_LIBRARY_PATH

# === Create Results Directory ===
# Allow override via environment variable (for sweep mode)
if [ -n "$RESULTS_DIR" ]; then
  # Use provided RESULTS_DIR (e.g., for decomposition sweeps)
  RESULTS_DIR="$RESULTS_DIR"
elif [ "$MODE" = "benchmark" ]; then
  # Add decomposition to directory name if specified
  if [ -n "$ADET_COMM" ] && [ -n "$BDET_COMM" ]; then
    RESULTS_DIR="$BENCHMARK_DIR/results/slurm_${SLURM_JOB_ID}_${DATASET}_${SLURM_NNODES}nodes_${ADET_COMM}x${BDET_COMM}"
  else
    RESULTS_DIR="$BENCHMARK_DIR/results/slurm_${SLURM_JOB_ID}_${DATASET}_${SLURM_NNODES}nodes"
  fi
else
  RESULTS_DIR="$BENCHMARK_DIR/profile_results/slurm_${SLURM_JOB_ID}_${DATASET}"
  ITERATIONS=1 # Force single iteration for profiling
fi
mkdir -p "$RESULTS_DIR"
cp "$0" "$RESULTS_DIR/job_script.sh"
cp "$ENV_SETUP" "$RESULTS_DIR/env_setup.sh" 2>/dev/null
env >"$RESULTS_DIR/job_environment.txt"

# === Dataset Paths ===
# ADETFILE can be overridden via environment variable (from Makefile)
case $DATASET in
fe4s4)
  FCIDUMP="$DATA_DIR/fe4s4/fcidump_Fe4S4.txt"
  ADETFILE="${ADETFILE:-$DATA_DIR/fe4s4/AlphaDets.txt}"
  ;;
n2)
  FCIDUMP="$DATA_DIR/n2/fcidump.txt"
  ADETFILE="${ADETFILE:-$DATA_DIR/n2/1em5-alpha.txt}"
  ;;
skqd)
  FCIDUMP="$DATA_DIR/skqd_paper/fcidump.txt"
  ADETFILE="${ADETFILE:-$DATA_DIR/skqd_paper/AlphaDets.txt}"
  ;;
*)
  echo "ERROR: Unknown dataset $DATASET"
  exit 1
  ;;
esac

# === Run Job ===
echo ""
echo "Starting $MODE at $(date --iso=seconds)"
echo ""

if [ "$MODE" = "benchmark" ]; then
  # === BENCHMARK MODE ===
  for i in $(seq 1 $REPLICATES); do
    echo "=== Replicate $i/$REPLICATES ==="
    LOGFILE="$RESULTS_DIR/benchmark_rep${i}.log"

    srun --export=ALL \
      $EXE_PATH --fcidump $FCIDUMP \
      --adetfile $ADETFILE \
      --method 0 \
      --block 10 \
      --iteration $ITERATIONS \
      --tolerance 1.0e-4 \
      --adet_comm_size $ADET_COMM \
      --bdet_comm_size $BDET_COMM \
      --task_comm_size $TASK_COMM \
      --init 0 \
      --shuffle 0 \
      --carryover_ratio 0.5 \
      --rdm 0 \
      2>&1 | tee "$LOGFILE"

    # Extract timing
    WALL_TIME=$(grep "Elapsed time for diagonalization" "$LOGFILE" | tail -1 | awk '{print $5}')
    DAVIDSON_TIME=$(grep "Elapsed time for davidson" "$LOGFILE" | tail -1 | awk '{print $5}')
    ENERGY=$(grep " Energy = " "$LOGFILE" | tail -1 | awk '{print $5}')
    echo "Replicate $i: Wall=$WALL_TIME s, Davidson=$DAVIDSON_TIME s, Energy=$ENERGY Ha" | tee -a "$RESULTS_DIR/summary.txt"

    [ $i -lt $REPLICATES ] && sleep 5
  done

  # === Benchmark Summary ===
  echo ""
  echo "Benchmark completed at $(date --iso=seconds)"

  if [ -f "$ANALYZER_PY" ]; then
    python3 "$ANALYZER_PY" "$RESULTS_DIR"/benchmark_rep*.log >"$RESULTS_DIR/final_summary.txt"
    cat "$RESULTS_DIR/final_summary.txt"
  fi

elif [ "$MODE" = "profile" ]; then
  # === PROFILE MODE ===
  PROFILE_LOG="$RESULTS_DIR/profile.log"
  ANALYSIS_OUT="$RESULTS_DIR/analysis.txt"

  # Run with per-rank rocprof output to avoid SQLite conflicts
  srun --export=ALL \
    bash -c "rocprof --stats --timestamp on \
                 -o $RESULTS_DIR/rocprof_rank\${SLURM_PROCID}.csv \
         $EXE_PATH --fcidump $FCIDUMP \
                   --adetfile $ADETFILE \
                   --method 0 \
                   --block 10 \
                   --iteration $ITERATIONS \
                   --tolerance 1.0e-4 \
                   --adet_comm_size $ADET_COMM \
                   --bdet_comm_size $BDET_COMM \
                   --task_comm_size $TASK_COMM \
                   --init 0 \
                   --shuffle 0 \
                   --carryover_ratio 0.5 \
                   --rdm 0" \
    2>&1 | tee "$PROFILE_LOG"

  # === Profile Summary ===
  echo ""
  echo "Profile completed at $(date --iso=seconds)"
  echo ""

  # List all generated profile files
  echo "Profile files generated for ranks:"
  ls -lh "$RESULTS_DIR"/rocprof_rank*.csv 2>/dev/null || echo "  WARNING: No rocprof output files found"
  echo ""

  # Analyze rank 0 profile (typically representative)
  if [ -f "$ANALYSIS_SCRIPT" ] && [ -f "$RESULTS_DIR/rocprof_rank0.csv" ]; then
    echo "Analyzing rank 0 profile results..."
    python3 "$ANALYSIS_SCRIPT" "$RESULTS_DIR/rocprof_rank0.csv" >"$ANALYSIS_OUT"

    echo ""
    echo "=== Top Functions (Rank 0) ==="
    head -30 "$ANALYSIS_OUT"
    echo ""
    echo "Full analysis saved to: $ANALYSIS_OUT"
    echo ""
    echo "To analyze other ranks, run:"
    echo "  python3 $ANALYSIS_SCRIPT $RESULTS_DIR/rocprof_rankN.csv"
  else
    if [ ! -f "$RESULTS_DIR/rocprof_rank0.csv" ]; then
      echo "WARNING: Rank 0 profile not found at $RESULTS_DIR/rocprof_rank0.csv"
    fi
    if [ ! -f "$ANALYSIS_SCRIPT" ]; then
      echo "WARNING: Analysis script not found at $ANALYSIS_SCRIPT"
    fi
  fi

  echo ""
  echo "Profile files summary:"
  echo "  - rocprof_rank*.csv  : Per-rank profiling data"
  echo "  - profile.log        : Application output"
  echo "  - analysis.txt       : Processed results (rank 0)"

else
  echo "ERROR: Unknown MODE=$MODE (must be 'benchmark' or 'profile')"
  exit 1
fi

echo "========================================="
echo "Results saved in: $RESULTS_DIR"
echo "========================================="
