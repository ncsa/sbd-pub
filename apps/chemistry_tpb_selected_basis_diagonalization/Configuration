# Path to the SBD library
SBD_PATH=../..

# choose the MPI C++ compiler wrapper
  CCCOM=mpicxx
# CCCOM=/opt/nvidia/hpc_sdk/Linux_x86_64/2025/comm_libs/mpi/bin/mpic++

# specify the underlying compiler (export OMPI_CXX for OpenMPI)
# export MPICH_CXX=g++
  export MPICH_CXX=/path/to/llvm/bin/clang++
# export MPICH_CXX=/path/to/hpc_sdk/Linux_x86_64/26.1/compilers/bin/nvc++

# flags for CPU build using nvc++ (use the correct -march or -mcpu flag for your CPUs)
# CCFLAGS = -O3 -march=neoverse-v2 -mp -DSBD_TRADMODE --diag_suppress declared_but_not_referenced
# additional flags for OpenMP-5 GPU build using nvc++ (NVIDIA GPUs only)
# CCFLAGS += -DUSE_GPU -DUSE_OMP_OFFLOAD -mp=gpu -gpu=cc100

# flags for CPU build using g++ or clang++ (use the correct -march or -mcpu flag for your CPUs)
  CCFLAGS = -O3 -fopenmp -march=znver3 -DSBD_TRADMODE 

# additional flags for OpenMP-5 GPU build using clang++ : GPU-aware MPI is required
#----------------------------------------------------------------------------------
# for AMD GPUs: -fopenmp-targets=amdgcn-amd-amdhsa --offload-arch=gfx90a
# use rocminfo | grep gfx to get the offload architecture
# for GPU-direct MPI on Frontier : export MPICH_GPU_SUPPORT_ENABLED=1 and add to LDFLAGS as follows
# LDFLAGS += -L/opt/cray/pe/mpich/9.0.1/gtl/lib -lmpi_gtl_hsa -L/opt/rocm-6.4.2/lib -lamdhip64 -lhsa-runtime64
#----------------------------------------------------------------------------------
# for NVIDIA GPUS: -fopenmp-targets=nvptx64-nvidia-cuda --offload-arch=sm_100 
# NVIDIA A100 sm_80,  H100 sm_90,  GB200 sm_100, B300 sm_103 etc.
#----------------------------------------------------------------------------------
  CCFLAGS += -DSBD_TRADMODE  -DUSE_GPU -DUSE_OMP_OFFLOAD -fopenmp-targets=amdgcn-amd-amdhsa --offload-arch=gfx90a \
             -fopenmp-offload-mandatory -foffload-lto
  LDFLAGS += -fopenmp --offload-arch=gfx90a -foffload-lto

